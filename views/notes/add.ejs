<% layout("/layouts/boilerplate") %>

<h3>Create a New Note</h3>

<br>

<form method="POST"
      action="/notes"
      novalidate
      class="needs-validation">

    <div class="row mt-3">

        <div class="col-8 offset-2">

            <div class="mb-3">

                <label class="form-label">
                    Title
                </label>

                <input
                    name="note[title]"
                    type="text"
                    class="form-control"
                    placeholder="Add a catchy title"
                    required
                >

                <div class="valid-feedback">
                    Title looks good
                </div>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Content
                </label>

                <textarea
                    name="note[content]"
                    placeholder="Enter description"
                    class="form-control"
                    required>
                </textarea>

                <div class="invalid-feedback">
                    Please enter valid content
                </div>

            </div>

            <button type="submit"
                    class="btn btn-dark mt-3">

                Create

            </button>

            <br><br>

        </div>

    </div>

</form>